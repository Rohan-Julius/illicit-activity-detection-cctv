## Public (browser-exposed) environment variables required by this app
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here
NEXT_PUBLIC_BACKEND_WS_BASE=ws://localhost:8000

## Supabase (server-side)
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

## Redis Configuration
REDIS_URL=redis://localhost:6379/0

## Storage & Paths
SUPABASE_CLIPS_BUCKET=clips
ZERODCE_WEIGHTS_PATH=../models/stage2_best.pth
YOLO_WEIGHTS_PATH=./models/best.pt
VIDEOMAE_WEIGHTS_PATH=./models/videomae_best.pth

## Video Processing
TARGET_FPS=12
DARK_BRIGHTNESS_THRESHOLD=0.50
YOLO_EVERY_N_FRAMES=3
YOLO_IMGSZ=640
ZERODCE_ENABLED=0
CLIP_FRAME_SIZE=224

## VideoMAE Settings
VIDEOMAE_MIN_CONF=0.70
VIDEOMAE_BASE_MODEL=MCG-NJU/videomae-base-finetuned-kinetics
VIDEOMAE_DROPOUT=0.3

## Clip Management
CLIP_ENQUEUE_ENABLED=1
CLIP_INCLUDE_30S_IN_REDIS=0
INCIDENT_COOLDOWN_SECONDS=15

## Twilio (SMS/WhatsApp Alerts)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_CHANNEL=whatsapp
TWILIO_PHONE_NUMBER=whatsapp:+14155238886
ALERT_TO_PHONE_NUMBER=+91xxxxxxxxxx

## Camera Management
AUTO_START_CAMERAS=1

